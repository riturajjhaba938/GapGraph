# Server Configuration
PORT=3001

# Database Configuration (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Example (Local Docker): postgresql://gapgraph:gapgraph_secret@localhost:5432/gapgraph?schema=public
# Example (Supabase): postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://username:password@localhost:5432/gapgraph?schema=public"

# AI Integration (OpenAI)
# Required for the LangChain Diagnoser, Planner, and Critic agents
# Leave blank to enable Dummy Mode (mock skills data for testing without LLM costs)
OPENAI_API_KEY="sk-proj-..."
